# Copy this file to .env and fill the values below.

# Arena API (required for real submissions)
ARENA_API_KEY=your_arena_api_key_here

# Keep the default unless you were told to use another Energy Arena API base.
ARENA_API_BASE_URL=https://api.energy-arena.org

# Built-in baseline source:
#   smard  -> default, no extra key required
#   entsoe -> optional advanced mode, requires ENTSOE_API_KEY below
BASELINE_DATA_SOURCE=smard

# Optional: only needed if you explicitly use --data_source entsoe.
# ENTSOE_API_KEY=your_entsoe_api_key_here
